# ============================================================
# ENVIRONMENT VARIABLES
# Copiar a .env y completar con valores reales.
# En produccion (Render), configurarlas en el dashboard.
# ============================================================

# Puerto (Render lo setea automaticamente)
PORT=3500

# Activar modo env vars (true en produccion, false en local con secrets.json)
USE_ENV_SECRETS=true

# GHL Agency PIT (legacy, no usado con OAuth)
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# GHL Company ID y Snapshot a aplicar
GHL_COMPANY_ID=xxxxxxxxxxxxxxxx
GHL_SNAPSHOT_ID=xxxxxxxxxxxxxxxx

# App 1 - Agency OAuth (crea sub-cuentas)
GHL_OAUTH_CLIENT_ID=xxxxxxxxxxxxxxxx-xxxxxxxx
GHL_OAUTH_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_OAUTH_REDIRECT_URI=https://localhost:3000/oauth/callback
GHL_OAUTH_ACCESS_TOKEN=eyJ...
GHL_OAUTH_REFRESH_TOKEN=eyJ...
GHL_OAUTH_TOKEN_EXPIRES_AT=0

# App 2 - Sub-Account OAuth (configura sub-cuentas)
GHL_OAUTH_SUBACCOUNT_CLIENT_ID=xxxxxxxxxxxxxxxx-xxxxxxxx
GHL_OAUTH_SUBACCOUNT_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_OAUTH_SUBACCOUNT_APP_ID=xxxxxxxxxxxxxxxx
GHL_OAUTH_SUBACCOUNT_BRIDGE_ACCESS_TOKEN=eyJ...
GHL_OAUTH_SUBACCOUNT_BRIDGE_REFRESH_TOKEN=eyJ...
